---
interface Props {
   libs?: string[]
}

const { libs = [] } = Astro.props

const availableLibs = {
   swiper: 'https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js',
   jquertyInputMask: 'https://cdnjs.cloudflare.com/ajax/libs/jquery.inputmask/5.0.7/jquery.inputmask.min.js',
   gsap: 'https://cdn.jsdelivr.net/npm/gsap@3.14.1/dist/gsap.min.js',
   gsapScrollTrigger: 'https://cdn.jsdelivr.net/npm/gsap@3.14.1/dist/ScrollTrigger.min.js',
   gsapDrawSvgPlugin: 'https://cdn.jsdelivr.net/npm/gsap@3.14.1/dist/DrawSVGPlugin.min.js',
   gsapScrollTo: 'https://cdn.jsdelivr.net/npm/gsap@3.14.1/dist/ScrollToPlugin.min.js',
   gsapSplitText: 'https://cdn.jsdelivr.net/npm/gsap@3.14.1/dist/SplitText.min.js',
   //   jqueryValidate: 'https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.js',

   //    simpleBar: 'https://unpkg.com/simplebar@latest/dist/simplebar.min.js',
   //    plyr: 'https://cdn.plyr.io/3.8.3/plyr.polyfilled.js',
}
---

<!-- jquery -->
<script
   is:inline
   src="https://code.jquery.com/jquery-3.7.1.min.js"
   integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo="
   crossorigin="anonymous"
></script>

{
   Object.values(availableLibs).map(lib => {
      return <script is:inline src={lib} />
   })
}

{}

<!-- main-js -->
<script is:inline src="./js/index.js"></script>
